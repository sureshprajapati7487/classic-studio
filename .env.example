# =============================
# Professional Editor Website
# Environment Variables Template
# =============================

# --- Backend Port ---
PORT=5000

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:5173

# --- JWT Secret (generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ---
# IMPORTANT: Use a long random string. Do NOT use simple passwords here.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_KEY_128_CHARS

# --- Admin Credentials ---
ADMIN_EMAIL=admin@youremail.com
ADMIN_PASSWORD=YourSecurePassword123

# --- Razorpay Payment (get from https://dashboard.razorpay.com) ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# --- Email / SMTP (for order notifications) ---
SMTP_EMAIL=yourgmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
NOTIFY_EMAIL=yourgmail@gmail.com

# --- Social Links ---
WHATSAPP_NUMBER=919587124896
INSTAGRAM_URL=https://instagram.com/yourprofile
EDITOR_NAME=Laxman Choudhary
